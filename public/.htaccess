RewriteEngine On

# Let the PHP API handle its own requests.
RewriteRule ^api/ - [L]

# Serve real files and directories as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback all frontend routes to the SPA entry.
RewriteRule ^ index.html [L]
